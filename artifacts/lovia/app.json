{
  "expo": {
    "name": "Lovia",
    "slug": "lovia",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "lovia",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a140f"
    },
    "ios": {
      "supportsTablet": false
    },
    "android": {
      "backgroundColor": "#0a140f",
      "package": "com.adeux.app",
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "0159de2c-8884-49cb-b5de-ee5f72d0499b"
      }
    },
    "owner": "l3ryx9"
  }
}
